<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{% if title %}{{ title }} — {% endif %}{{ settings.site_title }}</title>
  <meta name="description" content="{% if description %}{{ description }}{% else %}Directory of court mediation programs across all 20 judicial circuits in Florida.{% endif %}">
  <link rel="stylesheet" href="/css/style.css">
  <script src="https://identity.netlify.com/v1/netlify-identity-widget.js"></script>
</head>
<body>
  <a href="#main" class="skip-link">Skip to main content</a>

  <header class="site-header">
    <div class="container header-inner">
      <a href="/" class="site-logo">
        <span class="logo-title">{{ settings.site_title }}</span>
      </a>
      <button class="nav-toggle" aria-label="Toggle navigation" aria-expanded="false">
        <span class="nav-toggle-bar"></span>
        <span class="nav-toggle-bar"></span>
        <span class="nav-toggle-bar"></span>
      </button>
      <nav class="main-nav" aria-label="Main navigation">
        <ul class="nav-list">
          <li><a href="/"{% if page.url == "/" %} aria-current="page"{% endif %}>Home</a></li>
          <li><a href="/overview/"{% if page.url == "/overview/" %} aria-current="page"{% endif %}>Overview</a></li>
          <li class="nav-dropdown">
            <button class="nav-dropdown-toggle" aria-expanded="false">Circuits <span aria-hidden="true">&#9662;</span></button>
            <ul class="nav-dropdown-menu">
              {% for c in circuits %}
              <li><a href="/circuit/{{ c.circuit_number }}/">{{ c.circuit_number | ordinal }} — {{ c.counties | join(", ") }}</a></li>
              {% endfor %}
            </ul>
          </li>
          <li><a href="/about/"{% if page.url == "/about/" %} aria-current="page"{% endif %}>About</a></li>
          <li><a href="/contact/"{% if page.url == "/contact/" %} aria-current="page"{% endif %}>Contact</a></li>
        </ul>
      </nav>
    </div>
  </header>

  <main id="main" class="container">
    {{ content | safe }}
  </main>

  <footer class="site-footer">
    <div class="container">
      <p class="disclaimer">{{ settings.disclaimer }}</p>
      <div class="footer-links">
        <a href="https://www.flcourts.gov" target="_blank" rel="noopener">Florida Courts</a>
        <a href="https://www.flcourts.gov/Resources-Services/Alternative-Dispute-Resolution" target="_blank" rel="noopener">Florida DRC</a>
      </div>
      <p class="footer-updated">Last updated: {{ settings.last_updated }}</p>
    </div>
  </footer>

  <script>
    // Mobile nav toggle
    document.querySelector('.nav-toggle').addEventListener('click', function() {
      const nav = document.querySelector('.main-nav');
      const expanded = this.getAttribute('aria-expanded') === 'true';
      this.setAttribute('aria-expanded', !expanded);
      nav.classList.toggle('is-open');
    });

    // Dropdown toggle
    document.querySelectorAll('.nav-dropdown-toggle').forEach(function(btn) {
      btn.addEventListener('click', function(e) {
        e.preventDefault();
        const expanded = this.getAttribute('aria-expanded') === 'true';
        this.setAttribute('aria-expanded', !expanded);
        this.parentElement.classList.toggle('is-open');
      });
    });

    // Close dropdown when clicking outside
    document.addEventListener('click', function(e) {
      if (!e.target.closest('.nav-dropdown')) {
        document.querySelectorAll('.nav-dropdown.is-open').forEach(function(el) {
          el.classList.remove('is-open');
          el.querySelector('.nav-dropdown-toggle').setAttribute('aria-expanded', 'false');
        });
      }
    });

    // Netlify Identity redirect
    if (window.netlifyIdentity) {
      window.netlifyIdentity.on("init", function(user) {
        if (!user) {
          window.netlifyIdentity.on("login", function() {
            document.location.href = "/admin/";
          });
        }
      });
    }
  </script>
</body>
</html>
